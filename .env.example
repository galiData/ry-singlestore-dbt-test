# SingleStore Connection Settings
# Copy this file to .env and fill in your credentials

DBT_SINGLESTORE_HOST=your-host.singlestore.com
DBT_SINGLESTORE_PORT=3306
DBT_SINGLESTORE_USER=your_username
DBT_SINGLESTORE_PASSWORD=your_password
DBT_SINGLESTORE_DATABASE=your_database
DBT_SINGLESTORE_SCHEMA=your_schema
